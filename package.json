{
  "name": "devcoach",
  "displayName": "DevCoach",
  "version": "1.0.0",
  "description": "A real-time coding companion, productivity tracker, and digital discipline coach for VS Code.",
  "main": "dist/extension.js",
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "compile": "pnpm build",
    "vscode:prepublish": "pnpm build"
  },
  "icon": "media/icon.png",
  "keywords": [
    "vscode",
    "extension",
    "productivity",
    "coding",
    "coach",
    "tracker"
  ],
  "categories": [
    "Other",
    "Snippets"
  ],
  "author": "Cristian C.",
  "publisher": "cristiancibu",
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "vscode": "^1.1.37"
  },
  "activationEvents": [
    "onCommand:devcoach.start",
    "onCommand:devcoach.stats",
    "onCommand:devcoach.resume",
    "onCommand:devcoach.break",
    "onCommand:devcoach.burnout"
  ],
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cristiancibu/devcoach"
  },
  "bugs": {
    "url": "https://github.com/cristiancibu/devcoach/issues"
  },
  "homepage": "https://github.com/cristiancibu/devcoach#readme",
  "contributes": {
    "commands": [
      {
        "command": "devcoach.start",
        "title": "DevCoach: Start Session"
      },
      {
        "command": "devcoach.stats",
        "title": "DevCoach: Show Stats"
      },
      {
        "command": "devcoach.resume",
        "title": "DevCoach: Resume Session"
      },
      {
        "command": "devcoach.break",
        "title": "DevCoach: Take Break"
      },
      {
        "command": "devcoach.burnout",
        "title": "DevCoach: Burnout Status"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devcoach",
          "title": "DevCoach",
          "icon": "media/logo.png"
        }
      ]
    },
    "views": {
      "devcoach": [
        {
          "id": "devcoachView",
          "name": "Coach Panel",
          "type": "webview"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.85.0"
  }
}
